{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build-${presetName}",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "$env{QT_ROOT_DIR}"
      }
    },
    {
      "name": "linux-release",
      "displayName": "Linux Release",
      "inherits": "base",
      "generator": "Unix Makefiles",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" },
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "linux-debug",
      "displayName": "Linux Debug",
      "inherits": "linux-release",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "windows-msvc-release",
      "displayName": "Windows MSVC Release",
      "inherits": "base",
      "generator": "Visual Studio 17 2022",
      "architecture": { "value": "x64", "strategy": "set" },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" }
    },
    {
      "name": "windows-msvc-debug",
      "displayName": "Windows MSVC Debug",
      "inherits": "windows-msvc-release"
    },
    {
      "name": "macos-release",
      "displayName": "macOS Release",
      "inherits": "base",
      "generator": "Unix Makefiles",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" },
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "macos-debug",
      "displayName": "macOS Debug",
      "inherits": "macos-release",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    }
  ],
  "buildPresets": [
    { "name": "linux-release", "configurePreset": "linux-release" },
    { "name": "linux-debug", "configurePreset": "linux-debug" },
    {
      "name": "windows-msvc-release",
      "configurePreset": "windows-msvc-release",
      "configuration": "Release"
    },
    {
      "name": "windows-msvc-debug",
      "configurePreset": "windows-msvc-debug",
      "configuration": "Debug"
    },
    { "name": "macos-release", "configurePreset": "macos-release" },
    { "name": "macos-debug", "configurePreset": "macos-debug" }
  ],
  "testPresets": [
    {
      "name": "unit-linux",
      "configurePreset": "linux-release",
      "filter": { "include": { "label": "unit" } },
      "output": { "outputOnFailure": true }
    },
    {
      "name": "unit-windows",
      "configurePreset": "windows-msvc-release",
      "configuration": "Release",
      "filter": { "include": { "label": "unit" } },
      "output": { "outputOnFailure": true }
    },
    {
      "name": "unit-macos",
      "configurePreset": "macos-release",
      "filter": { "include": { "label": "unit" } },
      "output": { "outputOnFailure": true }
    },
    {
      "name": "shell-linux",
      "configurePreset": "linux-release",
      "filter": { "include": { "label": "shell" } },
      "output": { "outputOnFailure": true }
    },
    {
      "name": "shell-windows",
      "configurePreset": "windows-msvc-release",
      "configuration": "Release",
      "filter": { "include": { "label": "shell" } },
      "output": { "outputOnFailure": true }
    },
    {
      "name": "shell-macos",
      "configurePreset": "macos-release",
      "filter": { "include": { "label": "shell" } },
      "output": { "outputOnFailure": true }
    }
  ]
}
